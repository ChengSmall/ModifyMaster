{
  //值获取结构和修改器扩展

  /*
  值获取结构是在 https://github.com/ChengSmall/CsharpTemplates 库中的基础包内定义的json数据结构
  */

  //以下是修改器扩展定义

  "通过地址ID查询地址所在的值": {
    "type": "address", //type填写"address"，表示通过地址id引用地址处的值

    //此处填写datas数据下的地址ID，从指定地址获取数据，数据类型与dataType参数一致
    "id": "[地址id]",

    //从地址id处获取进程内存后，采用该参数指定的类型以确定值的字节大小和数据类型
    "dataType": "int32"
        /*
        dataType可填以下参数：
        int32 => 表示4字节整形
        uint32 => 表示4字节无符号整形
        int64 => 表示8字节整形
        float => 表示单精度浮点型（4个字节）
        double => 表示双精度浮点型（8个字节）
        int16 => 表示2字节整形
        uint16 => 表示2字节无符号整形
        byte => 表示单个字节的整数
        */
  }

}